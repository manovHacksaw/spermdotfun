# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed CORS origin(s) — set to your Vercel frontend URL
# Use * for development only
ALLOWED_ORIGIN=https://spermdotfun.vercel.app

# ── Avalanche / EVM ───────────────────────────────────────────────────────────
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_WS_RPC_URL=wss://api.avax-test.network/ext/bc/C/ws

# Deployed contract addresses
GAME_CONTRACT_ADDRESS=0x9b0d5bA04F99808c953FDd782057c08B5d0F32Dc
NEXT_PUBLIC_TOKEN_ADDRESS=0x9a30294499b8784b80096b6C6Dd87456972eCA70

# Server wallet — signs resolveBet payloads (KEEP SECRET, never commit)
SERVER_PRIVATE_KEY=0x...

# Set to true when using the SprmGame contract with Chainlink VRF support
VRF_ENABLED=true

# Maximum bet amount in SPRM (server-side guard)
MAX_BET_AMOUNT=10000

# ── Profile database ──────────────────────────────────────────────────────────
# Required for persistent stats. Without this the server runs in memory-only mode.
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname
# Alternative name (same purpose, one or the other is enough)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin key for POST /api/profile/backfill
PROFILE_ADMIN_KEY=your-secret-admin-key

# ── Profile tuning (optional) ─────────────────────────────────────────────────
# Auth nonce TTL in ms (default: 5 minutes)
# PROFILE_AUTH_NONCE_TTL_MS=300000

# Auth session TTL in ms (default: 24 hours)
# PROFILE_AUTH_SESSION_TTL_MS=86400000

# DB connection pool size (default: 10)
# PROFILE_DB_POOL_MAX=10

# DB idle connection timeout in ms (default: 30 000)
# PROFILE_DB_IDLE_TIMEOUT_MS=30000

# DB connection timeout in ms (default: 8 000)
# PROFILE_DB_CONNECT_TIMEOUT_MS=8000

# Set to false to skip automatic DB schema migrations on startup
# PROFILE_DB_AUTO_MIGRATE=true
